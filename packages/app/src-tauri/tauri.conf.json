{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "COH Companion",
	"version": "0.51.1",
	"identifier": "com.fknoobscoh.app",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "COH Companion",
				"label": "main",
				"width": 1800,
				"height": 1000,
				"transparent": true,
				"backgroundColor": "#3e3e3f",
				"dragDropEnabled": false,
				"url": "/splashscreen",
				"titleBarStyle": "Overlay"
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": ["$APPDATA/**"]
			}
		},
		"withGlobalTauri": true
	},
	"bundle": {
		"active": true,
		"publisher": "Code IT",
		"copyright": "Copyright © Code IT",
		"targets": ["msi"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"windows": {
			"wix": {
				"upgradeCode": "150f36d8-1af5-52f1-abfe-be2492789607"
			}
		}
	},
	"plugins": {
		"tauri-plugin-http": {
			"dangerousDisableDnsLookup": true,
			"dangerousDisableHostValidation": true,
			"dangerousAllowHttpOnProduction": true,
			"dangerousAcceptInvalidCerts": true
		},
		"sql": {
			"preload": ["sqlite:app.dev.db"]
		}
	}
}
