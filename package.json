{
	"name": "fknoobscoh",
	"version": "0.1.0",
	"description": "",
	"type": "module",
	"scripts": {
		"dev": "start pnpm run pb:up && start vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"tauri": "tauri",
		"tauri:build:linux": "tauri build --target x86_64-unknown-linux-gnu",
		"tauri:build:macos": "tauri build --target x86_64-apple-darwin",
		"tauri:build:windows": "tauri build --target x86_64-pc-windows-msvc",
		"pocketbase:typegen": "npx pocketbase-typegen --env --out src/lib/core/pocketbase/types.ts",
		"pb:up": "cd ./pocketbase & pocketbase serve",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"sign": "powershell -ExecutionPolicy Bypass -File ./.sign-windows.ps1"
	},
	"license": "MIT",
