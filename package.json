{
	"name": "fknoobscoh-workspace",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -n pocketbase,tauri -c blue,magenta \"pnpm pb:up\" \"pnpm --filter app tauri dev\"",
		"build": "pnpm --filter app tauri build",
		"pb:up": "pnpm --filter pocketbase serve",
		"pb:down": "pnpm --filter pocketbase down",
		"overlays:dev": "pnpm --filter overlays dev",
		"overlays:build": "pnpm --filter overlays build",
		"check": "pnpm -r check",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"changeset": "changeset",
		"version-packages": "node scripts/version.mjs",
		"release": "changeset publish"
	},
	"license": "MIT",
	"devDependencies": {
		"@changesets/cli": "^2.28.1",
		"concurrently": "^10.0.3",
		"prettier": "3.7.4",
		"prettier-plugin-svelte": "3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"@fknoobs/replay-parser"
		]
	}
}
